# GCP Cache Infrastructure Configuration
# Copy this to .env.gcp and fill in actual values from deployment

# ============================================================================
# Project Configuration
# ============================================================================

# GCP Project ID
GCP_PROJECT_ID=ttb-lang1

# Default region for all GCP services
REGION=us-central1

# ============================================================================
# Layer 0: Secret Manager (API Keys)
# ============================================================================

# Secrets are stored in GCP Secret Manager, not .env
# The application will fetch them at startup
# No .env configuration needed - just ensure service account has access

# Run this to create secrets:
#   gcloud secrets create finnhub-api-key --replication-policy=automatic
#   gcloud secrets create alpha-vantage-api-key --replication-policy=automatic

# ============================================================================
# Layer 1: Memorystore/Redis
# ============================================================================

# Redis host (from: gcloud redis instances describe mcp-cache-prod --format="value(host)")
REDIS_HOST=10.0.0.3
REDIS_PORT=6379

# Redis connection pool settings
REDIS_MAX_CONNECTIONS=50
REDIS_TIMEOUT=5
REDIS_TTL=300

# ============================================================================
# Layer 2a: Firestore
# ============================================================================

# Firestore is automatically enabled in GCP project
# No additional configuration needed
# Uses GCP_PROJECT_ID automatically

# ============================================================================
# Layer 2b: Cloud Storage
# ============================================================================

# Cloud Storage bucket for historical data
BUCKET_NAME=mcp-cache-historical

# Cloud Storage settings
GCS_CHUNK_SIZE=262144
GCS_TIMEOUT=30

# ============================================================================
# Layer 3: BigQuery
# ============================================================================

# BigQuery dataset for pre-computed metrics
# Uses GCP_PROJECT_ID automatically

# BigQuery dataset name (must exist)
BIGQUERY_DATASET=mcp_cache

# Query timeout in seconds
BIGQUERY_TIMEOUT=10

# ============================================================================
# Layer 4: Cloud Tasks
# ============================================================================

# Cloud Tasks queue for background refresh
CLOUD_TASKS_QUEUE=mcp-cache-refresh

# Cloud Tasks region (same as primary region)
CLOUD_TASKS_REGION=us-central1

# API endpoint for cache refresh handler
# Point to your Cloud Run service
CACHE_REFRESH_URL=https://mcp-backend.cloud.run/api/cache-refresh

# Cloud Tasks settings
CLOUD_TASKS_MAX_RETRIES=5
CLOUD_TASKS_MAX_BACKOFF=600
CLOUD_TASKS_MIN_BACKOFF=5

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable structured logging for Cloud Logging
ENABLE_CLOUD_LOGGING=true

# ============================================================================
# Application Settings
# ============================================================================

# Default cache TTL in seconds (all layers)
DEFAULT_CACHE_TTL=300

# Enable cache for each layer (set to false to disable)
ENABLE_LAYER_REDIS=true
ENABLE_LAYER_FIRESTORE=true
ENABLE_LAYER_STORAGE=true
ENABLE_LAYER_BIGQUERY=true
ENABLE_LAYER_CLOUD_TASKS=true

# ============================================================================
# Cloud Run Deployment Settings
# ============================================================================

# Service name
SERVICE_NAME=mcp-backend

# Memory allocation
MEMORY=2Gi

# CPU allocation
CPU=2

# Request timeout
TIMEOUT=3600

# Concurrency
CONCURRENCY=100

# ============================================================================
# Development/Testing Settings
# ============================================================================

# Skip GCP service checks on startup (for local testing)
SKIP_GCP_VALIDATION=false

# Use local Redis if GCP Redis unavailable
FALLBACK_TO_LOCAL_REDIS=false

# Mock mode (testing only - do NOT use in production)
MOCK_MODE=false

# ============================================================================
# Notes
# ============================================================================

# For local development:
#   - Set REDIS_HOST=localhost (if running local Redis)
#   - Set SKIP_GCP_VALIDATION=true
#   - Use Firebase emulator for Firestore

# For Cloud Run deployment:
#   - Use gcloud run deploy with --env-vars-file=.env.gcp
#   - Or pass individual vars with --set-env-vars=KEY=VALUE

# To generate this file automatically:
#   ./scripts/deploy_gcp_cache_infrastructure.sh
